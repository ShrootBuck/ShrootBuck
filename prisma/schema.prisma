// https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Status {
  id       String  @id
  value    String
  timezone String?
}

model SleepInterval {
  id        String   @id @default(cuid())
  startedAt DateTime @unique
  endedAt   DateTime
  createdAt DateTime @default(now())
}
